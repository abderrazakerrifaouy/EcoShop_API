        "/api/orders": {
            "post": {
                "tags": [
                    "Orders"
                ],
                "summary": "Create a new order",
                "operationId": "69a48b8c7cb177955d5c615348201c4e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "order",
                                    "ItemsOrder"
                                ],
                                "properties": {
                                    "order": {
                                        "required": [
                                            "user_id",
                                            "total_price",
                                            "status",
                                            "shipping_address"
                                        ],
                                        "properties": {
                                            "user_id": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "total_price": {
                                                "type": "number",
                                                "format": "float",
                                                "example": 99.99
                                            },
                                            "status": {
                                                "type": "string",
                                                "example": "pending"
                                            },
                                            "shipping_address": {
                                                "type": "string",
                                                "example": "123 Street, Casablanca"
                                            }
                                        },
                                        "type": "object"
                                    },
                                    "ItemsOrder": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "productId",
                                                "quantity",
                                                "price"
                                            ],
                                            "properties": {
                                                "productId": {
                                                    "type": "integer",
                                                    "example": 5
                                                },
                                                "quantity": {
                                                    "type": "integer",
                                                    "example": 2,
                                                    "minimum": 1
                                                },
                                                "price": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 45.5,
                                                    "minimum": 0
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Order created"
                    },
                    "422": {
                        "description": "Validation Error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
